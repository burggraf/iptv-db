server {
    listen 80;
    server_name zzzx.uk;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name zzzx.uk;

    ssl_certificate /etc/letsencrypt/live/zzzx.uk/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/zzzx.uk/privkey.pem;

    # M3U playlists served as static files from pb_public
    location ~ ^/([a-z0-9][a-z0-9_-]*)\.m3u$ {
        alias /opt/iptv/pb_public/$1.m3u;
        types { audio/x-mpegurl m3u; }
    }

    # SPA frontend (served by PocketBase)
    location / {
        proxy_pass http://127.0.0.1:8090;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # Block PocketBase admin UI from public access
    location /_/ {
        deny all;
        return 403;
    }

    # Worker API
    location /worker/ {
        rewrite ^/worker/(.*) /$1 break;
        proxy_pass http://127.0.0.1:3100;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_connect_timeout 60s;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}
